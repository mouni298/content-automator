# Google Gemini - script & research generation (free tier)
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Telegram review gate
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=123456789

# YouTube Data API (OAuth). Path to the client_secret JSON downloaded from
# Google Cloud Console (Desktop app credentials). Token cached after first run.
YOUTUBE_CLIENT_SECRET_FILE=secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json

# Instagram (phase 2 - leave blank for v1)
IG_USER_ID=
IG_ACCESS_TOKEN=
